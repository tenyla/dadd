-- SimpleUI Library
-- Usage: local UI = loadstring(game:HttpGet("YOUR_RAW_URL"))()

local SimpleUI = {}
SimpleUI.__index = SimpleUI

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local COLORS = {
    BG        = Color3.fromRGB(20, 20, 20),
    BG2       = Color3.fromRGB(30, 30, 30),
    BG3       = Color3.fromRGB(40, 40, 40),
    ACCENT    = Color3.fromRGB(90, 160, 255),
    TEXT      = Color3.fromRGB(220, 220, 220),
    SUBTEXT   = Color3.fromRGB(140, 140, 140),
    TOGGLE_ON = Color3.fromRGB(90, 160, 255),
    TOGGLE_OFF= Color3.fromRGB(60, 60, 60),
    BTN       = Color3.fromRGB(50, 50, 50),
}

local function tween(obj, props, t)
    TweenService:Create(obj, TweenInfo.new(t or 0.15), props):Play()
end

local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
    return c
end

local function label(parent, text, size, color, xalign)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.TextColor3 = color or COLORS.TEXT
    l.Font = Enum.Font.GothamBold
    l.TextSize = size or 13
    l.Text = text
    l.TextXAlignment = xalign or Enum.TextXAlignment.Left
    l.Size = UDim2.new(1, 0, 1, 0)
    l.Parent = parent
    return l
end

local function frame(parent, size, pos, color, transp)
    local f = Instance.new("Frame")
    f.Size = size
    f.Position = pos or UDim2.new(0,0,0,0)
    f.BackgroundColor3 = color or COLORS.BG2
    f.BackgroundTransparency = transp or 0
    f.BorderSizePixel = 0
    f.Parent = parent
    return f
end

local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or COLORS.ACCENT
    s.Thickness = thickness or 1
    s.Transparency = 0.5
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function listLayout(parent, padding, direction)
    local l = Instance.new("UIListLayout")
    l.Padding = UDim.new(0, padding or 5)
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.FillDirection = direction or Enum.FillDirection.Vertical
    l.Parent = parent
    return l
end

local function padding(parent, top, bottom, left, right)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top or 6)
    p.PaddingBottom = UDim.new(0, bottom or 6)
    p.PaddingLeft   = UDim.new(0, left or 8)
    p.PaddingRight  = UDim.new(0, right or 8)
    p.Parent = parent
    return p
end

-- Auto-resize a frame to its UIListLayout content
local function autoSize(layout, container, extra)
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        container.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y + (extra or 10))
    end)
end

---------------------------------------------------------------------------
-- Window
---------------------------------------------------------------------------
function SimpleUI.new(title, subtitle)
    local self = setmetatable({}, SimpleUI)

    -- Destroy existing instance
    pcall(function()
        if CoreGui:FindFirstChild("SimpleUI") then
            CoreGui:FindFirstChild("SimpleUI"):Destroy()
        end
    end)

    -- ScreenGui
    local sg = Instance.new("ScreenGui")
    sg.Name = "SimpleUI"
    sg.IgnoreGuiInset = true
    sg.ResetOnSpawn = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.Parent = CoreGui

    -- Main window
    local win = frame(sg, UDim2.new(0, 580, 0, 380), UDim2.new(0.5, -290, 0.5, -190), COLORS.BG)
    corner(win, 8)
    stroke(win, COLORS.ACCENT, 1.5)
    self._win = win

    -- Drag
    do
        local dragging, dragStart, startPos
        win.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true; dragStart = i.Position; startPos = win.Position
                i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then dragging = false end end)
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                local d = i.Position - dragStart
                win.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)
            end
        end)
    end

    -- Title bar
    local topBar = frame(win, UDim2.new(1, 0, 0, 38), nil, COLORS.BG2)
    topBar.Name = "TopBar"
    corner(topBar, 8)
    -- fix bottom corners of topbar
    local topFix = frame(topBar, UDim2.new(1, 0, 0, 8), UDim2.new(0, 0, 1, -8), COLORS.BG2)
    topFix.ZIndex = topBar.ZIndex

    -- Logo dot
    local dot = frame(topBar, UDim2.new(0, 10, 0, 10), UDim2.new(0, 14, 0.5, -5), COLORS.ACCENT)
    corner(dot, 5)

    local titleLbl = Instance.new("TextLabel")
    titleLbl.BackgroundTransparency = 1
    titleLbl.Position = UDim2.new(0, 32, 0, 0)
    titleLbl.Size = UDim2.new(1, -70, 1, 0)
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextSize = 14
    titleLbl.TextColor3 = COLORS.ACCENT
    titleLbl.Text = (title or "SimpleUI") .. (subtitle and ("  <font color='#888'>" .. subtitle .. "</font>") or "")
    titleLbl.RichText = true
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Parent = topBar

    -- Close / toggle button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 28, 0, 28)
    closeBtn.Position = UDim2.new(1, -34, 0.5, -14)
    closeBtn.BackgroundColor3 = COLORS.BG3
    closeBtn.Text = "×"
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 18
    closeBtn.TextColor3 = COLORS.TEXT
    closeBtn.Parent = topBar
    corner(closeBtn, 6)
    local visible = true
    closeBtn.MouseButton1Click:Connect(function()
        visible = not visible
        local body = win:FindFirstChild("Body")
        if body then body.Visible = visible end
        win.Size = visible and UDim2.new(0, 580, 0, 380) or UDim2.new(0, 580, 0, 38)
        closeBtn.Text = visible and "×" or "+"
    end)

    -- Body
    local body = frame(win, UDim2.new(1, 0, 1, -38), UDim2.new(0, 0, 0, 38), COLORS.BG)
    body.Name = "Body"
    body.ClipsDescendants = true

    -- Left sidebar (tab list)
    local sidebar = frame(body, UDim2.new(0, 160, 1, 0), nil, COLORS.BG2)
    local sbList = listLayout(sidebar, 4)
    padding(sidebar, 8, 8, 8, 8)
    autoSize(sbList, sidebar, 16)

    -- Right content area
    local content = frame(body, UDim2.new(1, -160, 1, 0), UDim2.new(0, 160, 0, 0), COLORS.BG)
    local contentScroll = Instance.new("ScrollingFrame")
    contentScroll.Size = UDim2.new(1, 0, 1, 0)
    contentScroll.BackgroundTransparency = 1
    contentScroll.ScrollBarThickness = 4
    contentScroll.ScrollBarImageColor3 = COLORS.ACCENT
    contentScroll.BorderSizePixel = 0
    contentScroll.CanvasSize = UDim2.new(0,0,0,0)
    contentScroll.Parent = content
    padding(contentScroll, 8, 8, 10, 10)
    local scrollList = listLayout(contentScroll, 8)
    scrollList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        contentScroll.CanvasSize = UDim2.new(0,0,0,scrollList.AbsoluteContentSize.Y + 16)
    end)

    self._sidebar = sidebar
    self._contentScroll = contentScroll
    self._tabs = {}
    self._activeTab = nil
    self._tabButtons = {}

    return self
end

---------------------------------------------------------------------------
-- Tab
---------------------------------------------------------------------------
function SimpleUI:AddTab(name)
    -- Tab button in sidebar
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 30)
    btn.BackgroundColor3 = COLORS.BG3
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.BorderSizePixel = 0
    btn.Parent = self._sidebar
    corner(btn, 6)

    local indicator = frame(btn, UDim2.new(0, 3, 0.6, 0), UDim2.new(0, 0, 0.2, 0), COLORS.ACCENT)
    corner(indicator, 3)
    indicator.BackgroundTransparency = 1

    local lbl = label(btn, name, 13, COLORS.SUBTEXT)
    lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.Size = UDim2.new(1, -12, 1, 0)

    -- Container in content
    local container = frame(self._contentScroll, UDim2.new(1, 0, 0, 0), nil, Color3.new(0,0,0), 1)
    container.Name = name
    container.Visible = false
    container.AutomaticSize = Enum.AutomaticSize.Y
    local conList = listLayout(container, 6)

    local tabObj = { _container = container, _list = conList, _name = name }

    local function activate()
        -- Hide all
        for _, t in pairs(self._tabs) do
            t._container.Visible = false
        end
        for _, b in pairs(self._tabButtons) do
            tween(b.btn, { BackgroundTransparency = 1 })
            tween(b.lbl, { TextColor3 = COLORS.SUBTEXT })
            tween(b.ind, { BackgroundTransparency = 1 })
        end
        -- Show this
        container.Visible = true
        tween(btn, { BackgroundTransparency = 0, BackgroundColor3 = COLORS.BG3 })
        tween(lbl, { TextColor3 = COLORS.TEXT })
        tween(indicator, { BackgroundTransparency = 0 })
        self._activeTab = tabObj
        self._contentScroll.CanvasPosition = Vector2.new(0, 0)
    end

    btn.MouseButton1Click:Connect(activate)
    table.insert(self._tabButtons, { btn = btn, lbl = lbl, ind = indicator })
    table.insert(self._tabs, tabObj)

    -- Activate first tab automatically
    if #self._tabs == 1 then
        activate()
    end

    ---------------------------------------------------------------------------
    -- Section
    ---------------------------------------------------------------------------
    function tabObj:AddSection(sectionName)
        local sec = frame(container, UDim2.new(1, 0, 0, 0), nil, COLORS.BG2)
        sec.AutomaticSize = Enum.AutomaticSize.Y
        corner(sec, 6)
        padding(sec, 8, 8, 8, 8)
        local secList = listLayout(sec, 5)

        -- Section title
        local titleRow = frame(sec, UDim2.new(1, 0, 0, 18), nil, Color3.new(0,0,0), 1)
        local titleTxt = label(titleRow, sectionName, 12, COLORS.ACCENT)
        titleTxt.Font = Enum.Font.GothamBold

        local line = frame(titleRow, UDim2.new(1, 0, 0, 1), UDim2.new(0, 0, 1, -1), COLORS.ACCENT)
        line.BackgroundTransparency = 0.7

        local secObj = {}

        -----------------------------------------------------------------
        -- Toggle
        -----------------------------------------------------------------
        function secObj:AddToggle(opts, callback)
            opts = opts or {}
            local state = opts.Default or false
            local cb = callback or function() end

            local row = frame(sec, UDim2.new(1, 0, 0, 38), nil, COLORS.BG3)
            corner(row, 6)
            padding(row, 0, 0, 10, 10)

            local nameLbl = label(row, opts.Title or "Toggle", 13, COLORS.TEXT)
            nameLbl.Size = UDim2.new(1, -50, 0, 18)
            nameLbl.Position = UDim2.new(0, 0, 0, 4)

            if opts.Desc then
                local descLbl = label(row, opts.Desc, 11, COLORS.SUBTEXT)
                descLbl.Size = UDim2.new(1, -50, 0, 14)
                descLbl.Position = UDim2.new(0, 0, 0, 22)
                descLbl.TextWrapped = true
                row.Size = UDim2.new(1, 0, 0, 52)
            end

            -- Toggle switch
            local trackBG = frame(row, UDim2.new(0, 36, 0, 20), UDim2.new(1, -46, 0.5, -10), state and COLORS.TOGGLE_ON or COLORS.TOGGLE_OFF)
            corner(trackBG, 10)
            local knob = frame(trackBG, UDim2.new(0, 16, 0, 16), UDim2.new(0, state and 18 or 2, 0.5, -8), Color3.new(1,1,1))
            corner(knob, 8)

            local clickBtn = Instance.new("TextButton")
            clickBtn.Size = UDim2.new(1, 0, 1, 0)
            clickBtn.BackgroundTransparency = 1
            clickBtn.Text = ""
            clickBtn.Parent = row

            local function update(v)
                state = v
                tween(trackBG, { BackgroundColor3 = state and COLORS.TOGGLE_ON or COLORS.TOGGLE_OFF })
                tween(knob, { Position = UDim2.new(0, state and 18 or 2, 0.5, -8) })
                pcall(cb, state)
            end

            clickBtn.MouseButton1Click:Connect(function() update(not state) end)

            local ctrl = {
                Set = function(_, v) update(v) end,
                Get = function(_) return state end,
            }
            return ctrl
        end

        -----------------------------------------------------------------
        -- Slider
        -----------------------------------------------------------------
        function secObj:AddSlider(opts, callback)
            opts = opts or {}
            local min = opts.Min or 0
            local max = opts.Max or 100
            local val = math.clamp(opts.Default or min, min, max)
            local precise = opts.Precise or false
            local cb = callback or function() end

            local row = frame(sec, UDim2.new(1, 0, 0, 52), nil, COLORS.BG3)
            corner(row, 6)
            padding(row, 0, 0, 10, 10)

            local nameLbl = label(row, opts.Title or "Slider", 13, COLORS.TEXT)
            nameLbl.Size = UDim2.new(1, -60, 0, 20)
            nameLbl.Position = UDim2.new(0, 0, 0, 4)

            local valLbl = label(row, tostring(val), 12, COLORS.ACCENT, Enum.TextXAlignment.Right)
            valLbl.Size = UDim2.new(0, 55, 0, 20)
            valLbl.Position = UDim2.new(1, -55, 0, 4)

            local track = frame(row, UDim2.new(1, 0, 0, 6), UDim2.new(0, 0, 0, 34), COLORS.BG)
            corner(track, 3)
            local fill = frame(track, UDim2.new((val-min)/(max-min), 0, 1, 0), nil, COLORS.ACCENT)
            corner(fill, 3)

            local mouse = game.Players.LocalPlayer:GetMouse()
            local sliding = false

            local function updateSlider(mx)
                local abs = track.AbsolutePosition.X
                local sz  = track.AbsoluteSize.X
                local pct = math.clamp((mx - abs) / sz, 0, 1)
                val = precise
                    and tonumber(string.format("%.1f", min + (max-min)*pct))
                    or  math.floor(min + (max-min)*pct + 0.5)
                fill.Size = UDim2.new(pct, 0, 1, 0)
                valLbl.Text = tostring(val)
                pcall(cb, val)
            end

            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 1, 0)
            btn.BackgroundTransparency = 1
            btn.Text = ""
            btn.Parent = track
            btn.MouseButton1Down:Connect(function() sliding = true end)
            game:GetService("UserInputService").InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
            end)
            game:GetService("RunService").Heartbeat:Connect(function()
                if sliding then updateSlider(mouse.X) end
            end)

            local ctrl = {
                Set = function(_, v)
                    val = math.clamp(v, min, max)
                    fill.Size = UDim2.new((val-min)/(max-min), 0, 1, 0)
                    valLbl.Text = tostring(val)
                    pcall(cb, val)
                end,
                Get = function(_) return val end,
            }
            return ctrl
        end

        -----------------------------------------------------------------
        -- Button
        -----------------------------------------------------------------
        function secObj:AddButton(opts, callback)
            opts = opts or {}
            local cb = callback or function() end

            local row = frame(sec, UDim2.new(1, 0, 0, 32), nil, COLORS.ACCENT)
            corner(row, 6)
            row.BackgroundTransparency = 0.4

            local lbl2 = label(row, opts.Title or "Button", 13, COLORS.TEXT, Enum.TextXAlignment.Center)

            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 1, 0)
            btn.BackgroundTransparency = 1
            btn.Text = ""
            btn.Parent = row

            btn.MouseButton1Down:Connect(function() tween(row, { BackgroundTransparency = 0.1 }) end)
            btn.MouseButton1Click:Connect(function()
                tween(row, { BackgroundTransparency = 0.4 })
                pcall(cb)
            end)
            btn.MouseLeave:Connect(function() tween(row, { BackgroundTransparency = 0.4 }) end)

            return {}
        end

        -----------------------------------------------------------------
        -- TextBox
        -----------------------------------------------------------------
        function secObj:AddTextBox(opts, callback)
            opts = opts or {}
            local cb = callback or function() end

            local row = frame(sec, UDim2.new(1, 0, 0, 52), nil, COLORS.BG3)
            corner(row, 6)
            padding(row, 0, 0, 10, 10)

            local nameLbl = label(row, opts.Title or "TextBox", 13, COLORS.TEXT)
            nameLbl.Size = UDim2.new(1, 0, 0, 20)
            nameLbl.Position = UDim2.new(0, 0, 0, 4)

            local inputBG = frame(row, UDim2.new(1, 0, 0, 22), UDim2.new(0, 0, 0, 28), COLORS.BG)
            corner(inputBG, 4)
            stroke(inputBG, COLORS.ACCENT, 1)

            local tb = Instance.new("TextBox")
            tb.Size = UDim2.new(1, -10, 1, 0)
            tb.Position = UDim2.new(0, 5, 0, 0)
            tb.BackgroundTransparency = 1
            tb.Font = Enum.Font.GothamBold
            tb.TextSize = 12
            tb.TextColor3 = COLORS.TEXT
            tb.PlaceholderText = opts.Placeholder or "Enter value..."
            tb.PlaceholderColor3 = COLORS.SUBTEXT
            tb.Text = opts.Default or ""
            tb.TextXAlignment = Enum.TextXAlignment.Left
            tb.ClearTextOnFocus = false
            tb.Parent = inputBG

            tb.FocusLost:Connect(function(enter)
                if enter and tb.Text ~= "" then pcall(cb, tb.Text) end
            end)

            local ctrl = {
                Set = function(_, v)
                    tb.Text = tostring(v)
                    pcall(cb, v)
                end,
                Get = function(_) return tb.Text end,
            }
            return ctrl
        end

        -----------------------------------------------------------------
        -- Dropdown
        -----------------------------------------------------------------
        function secObj:AddDropdown(opts, callback)
            opts = opts or {}
            local list = opts.List or {}
            local cb   = callback or function() end
            local sel  = opts.Default or list[1]

            local row = frame(sec, UDim2.new(1, 0, 0, 52), nil, COLORS.BG3)
            row.ClipsDescendants = true
            corner(row, 6)
            padding(row, 0, 0, 10, 10)

            local nameLbl = label(row, opts.Title or "Dropdown", 13, COLORS.TEXT)
            nameLbl.Size = UDim2.new(1, 0, 0, 20)
            nameLbl.Position = UDim2.new(0, 0, 0, 4)

            local selBG = frame(row, UDim2.new(1, 0, 0, 24), UDim2.new(0, 0, 0, 26), COLORS.BG)
            corner(selBG, 4)
            stroke(selBG, COLORS.ACCENT, 1)

            local selLbl = label(selBG, tostring(sel), 12, COLORS.TEXT)
            selLbl.Position = UDim2.new(0, 6, 0, 0)
            selLbl.Size = UDim2.new(1, -28, 1, 0)

            local arrow = label(selBG, "▼", 10, COLORS.ACCENT, Enum.TextXAlignment.Right)
            arrow.Size = UDim2.new(0, 20, 1, 0)
            arrow.Position = UDim2.new(1, -22, 0, 0)

            -- Dropdown list
            local dropFrame = frame(row, UDim2.new(1, 0, 0, 0), UDim2.new(0, 0, 0, 52), COLORS.BG)
            corner(dropFrame, 4)
            stroke(dropFrame, COLORS.ACCENT, 1)
            dropFrame.ClipsDescendants = true
            dropFrame.ZIndex = 5

            local dList = listLayout(dropFrame, 2)
            dList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                dropFrame.Size = UDim2.new(1, 0, 0, dList.AbsoluteContentSize.Y + 6)
            end)

            for _, item in ipairs(list) do
                local itemBtn = Instance.new("TextButton")
                itemBtn.Size = UDim2.new(1, 0, 0, 24)
                itemBtn.BackgroundTransparency = 1
                itemBtn.Text = ""
                itemBtn.Parent = dropFrame

                local itemLbl = label(itemBtn, tostring(item), 12, COLORS.TEXT)
                itemLbl.Position = UDim2.new(0, 8, 0, 0)

                itemBtn.MouseEnter:Connect(function() tween(itemBtn, { BackgroundTransparency = 0, BackgroundColor3 = COLORS.BG3 }) end)
                itemBtn.MouseLeave:Connect(function() tween(itemBtn, { BackgroundTransparency = 1 }) end)
                itemBtn.MouseButton1Click:Connect(function()
                    sel = item
                    selLbl.Text = tostring(item)
                    local open = dropFrame.Visible
                    dropFrame.Visible = false
                    row.Size = UDim2.new(1, 0, 0, 52)
                    arrow.Text = "▼"
                    pcall(cb, item)
                end)
            end

            local open = false
            local openBtn = Instance.new("TextButton")
            openBtn.Size = UDim2.new(1, 0, 1, 0)
            openBtn.BackgroundTransparency = 1
            openBtn.Text = ""
            openBtn.Parent = selBG
            openBtn.MouseButton1Click:Connect(function()
                open = not open
                dropFrame.Visible = open
                arrow.Text = open and "▲" or "▼"
                if open then
                    row.Size = UDim2.new(1, 0, 0, 52 + dropFrame.AbsoluteSize.Y + 4)
                else
                    row.Size = UDim2.new(1, 0, 0, 52)
                end
            end)

            local ctrl = {
                Set = function(_, v)
                    sel = v
                    selLbl.Text = tostring(v)
                    pcall(cb, v)
                end,
                Get = function(_) return sel end,
            }
            return ctrl
        end

        -----------------------------------------------------------------
        -- Label
        -----------------------------------------------------------------
        function secObj:AddLabel(text, color)
            local row = frame(sec, UDim2.new(1, 0, 0, 0), nil, Color3.new(0,0,0), 1)
            row.AutomaticSize = Enum.AutomaticSize.Y
            local lbl2 = label(row, text or "", 12, color or COLORS.SUBTEXT)
            lbl2.TextWrapped = true
            lbl2.AutomaticSize = Enum.AutomaticSize.Y
            lbl2.Size = UDim2.new(1, 0, 0, 0)
            local ctrl = {
                Set = function(_, v) lbl2.Text = v end,
                SetColor = function(_, c) lbl2.TextColor3 = c end,
            }
            return ctrl
        end

        return secObj
    end

    return tabObj
end

---------------------------------------------------------------------------
-- Notification
---------------------------------------------------------------------------
function SimpleUI:Notify(opts)
    opts = opts or {}
    local title   = opts.Title or "Notification"
    local desc    = opts.Desc or ""
    local duration = opts.Duration or 5

    local sg = CoreGui:FindFirstChild("SimpleUI")
    if not sg then return end

    local container = sg:FindFirstChild("NotifContainer")
    if not container then
        container = Instance.new("Frame")
        container.Name = "NotifContainer"
        container.AnchorPoint = Vector2.new(1, 1)
        container.Position = UDim2.new(1, -10, 1, -10)
        container.Size = UDim2.new(0, 280, 1, -20)
        container.BackgroundTransparency = 1
        container.BorderSizePixel = 0
        container.Parent = sg
        local cl = listLayout(container, 6, Enum.FillDirection.Vertical)
        cl.VerticalAlignment = Enum.VerticalAlignment.Bottom
    end

    local notif = frame(container, UDim2.new(1, 0, 0, 0), nil, COLORS.BG2)
    notif.AutomaticSize = Enum.AutomaticSize.Y
    notif.Position = UDim2.new(1, 0, 0, 0)
    corner(notif, 6)
    stroke(notif, COLORS.ACCENT, 1)
    padding(notif, 8, 8, 10, 10)

    local inner = frame(notif, UDim2.new(1, 0, 0, 0), nil, Color3.new(0,0,0), 1)
    inner.AutomaticSize = Enum.AutomaticSize.Y
    local il = listLayout(inner, 3)

    local tLbl = label(inner, title, 13, COLORS.ACCENT)
    tLbl.Size = UDim2.new(1, 0, 0, 16)
    tLbl.AutomaticSize = Enum.AutomaticSize.Y

    if desc ~= "" then
        local dLbl = label(inner, desc, 11, COLORS.TEXT)
        dLbl.Size = UDim2.new(1, 0, 0, 0)
        dLbl.AutomaticSize = Enum.AutomaticSize.Y
        dLbl.TextWrapped = true
    end

    tween(notif, { Position = UDim2.new(0, 0, 0, 0) }, 0.3)
    task.delay(duration, function()
        tween(notif, { Position = UDim2.new(1.2, 0, 0, 0) }, 0.3)
        task.wait(0.35)
        notif:Destroy()
    end)
end

return SimpleUI
